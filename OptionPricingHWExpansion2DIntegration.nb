Cell[BoxData[
 RowBox[{
  RowBox[{"FLtail", "[", "rho_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Log", "[", 
