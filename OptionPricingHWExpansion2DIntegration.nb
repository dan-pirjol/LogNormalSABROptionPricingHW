Cell[BoxData[
 RowBox[{
  RowBox[{"GLtail", "[", "rho_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"Sqrt", "[", 
    RowBox[{"Log", "[", 
     RowBox[{"1", "/", "rho"}], "]"}], "]"}], "-", 
   RowBox[{
    RowBox[{"rho", "^", "2"}], " ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "/", "rho"}], "]"}], "]"}]}], "+", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"Log", "[", 
        RowBox[{"2", 
         RowBox[{"Log", "[", 
          RowBox[{"1", "/", "rho"}], "]"}]}], "]"}]}], ")"}], "/", "2"}], "/", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "/", "rho"}], "]"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.832420655872326*^9, 3.8324206673594513`*^9}},
