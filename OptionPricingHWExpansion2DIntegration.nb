Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"The", " ", "density", " ", "of", " ", 
    RowBox[{"1", "/", "t"}], " ", "A", 
    RowBox[{"(", 
     RowBox[{"t", ",", "mu"}], ")"}], " ", "depends", " ", "on", " ", "H", 
    RowBox[{"(", 
     RowBox[{"rho", ",", "a"}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"F", 
     RowBox[{"(", "rho", ")"}]}], "-", 
    RowBox[{
     RowBox[{
      RowBox[{"pi", "^", "2"}], "/", 
      RowBox[{"+", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{
          RowBox[{"a", "^", "2"}], "*", 
          RowBox[{"rho", "^", "2"}]}]}], ")"}]}]}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "a"}], ")"}]}]}]}], " ", "*)"}]], "Input",
