        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"1", "/", 
           RowBox[{"Log", "[", 
            RowBox[{"1", "/", "rho"}], "]"}]}]}], ")"}]}], "+", 
       RowBox[{
        RowBox[{"rho", "^", "2"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"Log", "[", "rho", "]"}]}], ")"}], "^", "2"}]}], "-", 
       "1"}], ")"}], "^", "2"}]}], "+", 
   RowBox[{
    RowBox[{"Pi", "^", "2"}], "/", "2"}], " ", "-", 
   RowBox[{"1", "/", "2"}]}]}]], "Input",
