Cell[BoxData[
 RowBox[{
  RowBox[{"Fsum", "[", 
   RowBox[{"rho_", ",", "n_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"Pi", "^", "2"}], "/", "2"}], "-", "1", "+", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"dFcoeff", "[", 
