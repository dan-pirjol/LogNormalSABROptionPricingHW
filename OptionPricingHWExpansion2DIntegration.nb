Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"Change", " ", "of", " ", "variable", " ", "x"}], " ", "=", " ", 
   RowBox[{"Exp", "[", "z", "]"}]}], " ", "*)"}]], "Input",
 CellLabel->
  "In[1274]:=",ExpressionUUID->"36791f01-f6a2-4898-896b-6138f16548b0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"intAdensityLog", "[", 
   RowBox[{"z_", ",", "a_", ",", "mu_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{"mu", " ", "z"}], "]"}], " ", 
   RowBox[{"Gexp", "[", 
    RowBox[{"Exp", "[", "z", "]"}], "]"}], 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "t"}], " ", 
     RowBox[{"Hexp", "[", 
      RowBox[{
       RowBox[{"Exp", "[", "z", "]"}], ",", "a"}], "]"}]}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8324209411847553`*^9, 3.832420942311452*^9}},
 CellLabel->
  "In[1275]:=",ExpressionUUID->"cc07c347-d15a-43d6-bb5e-7c05a0ee296b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"numAIntegralLog", "[", 
   RowBox[{"a_", ",", "mu_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"intAdensityLog", "[", 
     RowBox[{"z", ",", "a", ",", "mu", ",", "t"}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"z", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[1276]:=",ExpressionUUID->"547dd71d-1388-4250-90bc-e338704603bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"AdensityLog", "[", 
   RowBox[{"a_", ",", "mu_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"2", "Pi", " ", "t"}], ")"}]}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "2"}], " ", 
     RowBox[{"mu", "^", "2"}], " ", "t"}], "]"}], " ", 
   RowBox[{"a", "^", 
    RowBox[{"(", 
     RowBox[{"mu", "-", "1"}], ")"}]}], " ", 
   RowBox[{"numAIntegralLog", "[", 
    RowBox[{"a", ",", "mu", ",", "t"}], "]"}]}]}]], "Input",
 CellLabel->
  "In[1277]:=",ExpressionUUID->"595ebc03-fcd8-4725-9c6f-c8fd9a4d6272"],

