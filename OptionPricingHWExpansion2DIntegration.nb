Cell[BoxData[
 RowBox[{
  RowBox[{"Gsum", "[", 
   RowBox[{"rho_", ",", "n_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"Sqrt", "[", "3", "]"}], 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"dGcoeff", "[", 
         RowBox[{"[", "j", "]"}], "]"}], " ", 
        RowBox[{
         RowBox[{"Log", "[", "rho", "]"}], "^", "j"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}], 
    ")"}]}]}]], "Input",
