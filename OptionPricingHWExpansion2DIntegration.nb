Cell[BoxData[
 RowBox[{
  RowBox[{"thetahatexp", "[", 
   RowBox[{"rho_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"2", "Pi", " ", "t"}], ")"}]}], 
   RowBox[{"Gexp", "[", "rho", "]"}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "t"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Pi", "^", "2"}]}], "/", "2"}], "+", 
       RowBox[{"Fexp", "[", "rho", "]"}]}], ")"}]}], "]"}]}]}]], "Input",
 CellLabel->
  "In[1265]:=",ExpressionUUID->"362f4acd-3fc6-4ed3-a716-8fbd05624216"],

