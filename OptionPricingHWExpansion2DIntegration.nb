Cell[BoxData[
 RowBox[{
  RowBox[{"normInt1DLog", "[", 
   RowBox[{"mu_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"Pi", " ", "t"}], ")"}]}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "2"}], " ", 
     RowBox[{"mu", "^", "2"}], " ", "t"}], "]"}], " ", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Gexp", "[", 
       RowBox[{"Exp", "[", "z", "]"}], "]"}], " ", 
      RowBox[{"BesselK", "[", 
       RowBox[{
        RowBox[{"-", "mu"}], ",", 
        RowBox[{
         RowBox[{"Exp", "[", "z", "]"}], "/", "t"}]}], "]"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "1"}], "/", "t"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Fexp", "[", 
           RowBox[{"Exp", "[", "z", "]"}], "]"}], "-", 
          RowBox[{
           RowBox[{"Pi", "^", "2"}], "/", "2"}]}], ")"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", 
       RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], 
    "]"}]}]}]], "Input",
 CellLabel->
  "In[1280]:=",ExpressionUUID->"44380638-5a3d-4793-8188-4a7db7a3d73f"],

