Cell[BoxData[
 RowBox[{
  RowBox[{"integrandAdensity", "[", 
   RowBox[{"x_", ",", "a_", ",", "mu_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"x", "^", "mu"}], " ", 
   RowBox[{"Gexp", "[", "x", "]"}], " ", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "/", "t"}], " ", 
      RowBox[{"Hexp", "[", 
       RowBox[{"x", ",", "a"}], "]"}]}], "]"}], "/", "x"}]}]}]], "Input",
 CellLabel->
  "In[1270]:=",ExpressionUUID->"d3e19ab2-54f5-470a-a40c-bb10cd3fc744"],

Cell[BoxData[
 RowBox[{
  RowBox[{"numAIntegral", "[", 
   RowBox[{"a_", ",", "mu_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"integrandAdensity", "[", 
     RowBox[{"x", ",", "a", ",", "mu", ",", "t"}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[1271]:=",ExpressionUUID->"36942dd7-2ba2-448f-9cdd-6e45d741b14e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Adensity", "[", 
   RowBox[{"a_", ",", "mu_", ",", "t_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"2", "Pi", " ", "t"}], ")"}]}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "2"}], " ", 
     RowBox[{"mu", "^", "2"}], " ", "t"}], "]"}], " ", 
   RowBox[{"a", "^", 
    RowBox[{"(", 
     RowBox[{"mu", "-", "1"}], ")"}]}], " ", 
   RowBox[{"numAIntegral", "[", 
    RowBox[{"a", ",", "mu", ",", "t"}], "]"}]}]}]], "Input",
 CellLabel->
  "In[1272]:=",ExpressionUUID->"e298fb9a-1712-4cbd-9dd4-e295f409ca0b"],

