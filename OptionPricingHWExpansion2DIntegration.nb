Cell[BoxData[
 RowBox[{
  RowBox[{"kernelC", "[", 
   RowBox[{"k_", ",", "z_", ",", "a_", ",", "mu_", ",", "t_", ",", "sig0_"}], 
   "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"a", " ", 
      RowBox[{"Exp", "[", "z", "]"}]}], ")"}], "^", "mu"}], " ", 
   RowBox[{"Gexp", "[", 
    RowBox[{"Exp", "[", "z", "]"}], "]"}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "t"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Fexp", "[", 
        RowBox[{"Exp", "[", "z", "]"}], "]"}], "-", 
       RowBox[{
        RowBox[{"Pi", "^", "2"}], "/", "2"}]}], ")"}]}], "]"}], " ", 
